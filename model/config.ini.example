[defaults]
output_dir = output
batch_size = 1
gradient_accumulation_steps = 8
learning_rate = 1e-4
num_train_epochs = 3

[model:gemma-4-e2b-it]
group = gemma
base_model = google/gemma-4-E2B-it

[dataset:rarity-quick-1000-split]
data_dir = data/datasets/rarity-quick-1000-split
prompt_column = prompt
text_column = response

[profile:socal-aircraft-rarity]
model = gemma-4-e2b-it
dataset = rarity-quick-1000-split
modality = text
text_sub_mode = instruction
max_seq_length = 2048
lora_r = 8
lora_alpha = 16
lora_dropout = 0.1
